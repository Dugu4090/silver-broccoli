ENV=development
APP_NAME=StudyMate AI
LOG_LEVEL=INFO
ENABLE_METRICS=true

# Security
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_MIN=30
JWT_REFRESH_DAYS=14
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# Database
DATABASE_URL=postgresql+asyncpg://studymate:studymate@postgres:5432/studymate
SYNC_DATABASE_URL=postgresql+psycopg2://studymate:studymate@postgres:5432/studymate

# Redis
REDIS_URL=redis://redis:6379/0

# Chroma
CHROMA_HOST=chroma
CHROMA_PORT=8000

# LLM
LLM_PROVIDER=ollama
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Admin bootstrap
ADMIN_EMAIL=admin@studymate.local
ADMIN_PASSWORD=admin1234

# Rate limit
RATE_LIMIT_PER_MINUTE=120
